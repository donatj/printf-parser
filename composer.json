{
	"name": "donatj/printf-parser",
	"description": "PHP printf-syntax compatible printf string parser. Parses printf strings into a stream of lexemes.",
	"type": "library",
	"require-dev": {
		"bamarni/composer-bin-plugin": "^1.8",
		"corpus/coding-standard": "^0.9.0",
		"donatj/drop": "~1",
		"friendsofphp/php-cs-fixer": "^3.94",
		"phpstan/phpstan": "=2.1.45",
		"phpunit/phpunit": "^12.5",
		"squizlabs/php_codesniffer": "^3.13"
	},
	"license": "MIT",
	"authors": [
		{
			"name": "Jesse Donat",
			"email": "donatj@gmail.com"
		}
	],
	"require": {
		"php": ">=7.4"
	},
	"autoload": {
		"psr-4": {
			"donatj\\Printf\\": "src/"
		}
	},
	"config": {
		"allow-plugins": {
			"bamarni/composer-bin-plugin": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"extra": {
		"bamarni-bin": {
			"bin-links": true,
			"forward-command": false
		}
	}
}
